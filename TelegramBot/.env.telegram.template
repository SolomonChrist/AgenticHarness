# 🦂 Agentic Harness — Telegram EA Bot Configuration
# Copy this file to .env.telegram and fill in your values.
# NEVER commit .env.telegram to git — it contains your credentials.

# ─────────────────────────────────────────────────────────
# STEP 1: Create your Telegram bot
# Open Telegram → search @BotFather → /newbot
# Follow prompts → copy the token it gives you
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─────────────────────────────────────────────────────────
# STEP 2: Get your Telegram user ID
# Open Telegram → search @userinfobot → send /start
# Copy the "Id:" number from the response
# Multiple users: comma-separated (e.g. 123456,789012)
# ─────────────────────────────────────────────────────────
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id_here

# ─────────────────────────────────────────────────────────
# STEP 3: Point to your projects folder
# This is the folder that CONTAINS all your project subfolders
# Windows example: C:\Users\YourName\MyAIProjects
# Mac/Linux example: /Users/yourname/MyAIProjects
# ─────────────────────────────────────────────────────────
HARNESS_PROJECTS_PATH=C:\Users\YourName\MyAIProjects

# ─────────────────────────────────────────────────────────
# OPTIONAL: Customize your bot's personality
# ─────────────────────────────────────────────────────────
# Your bot's name (shows in messages)
BOT_NAME=Harness Assistant

# Your name (bot uses it in greetings)
OWNER_NAME=there

# How often to check for new agent notifications (seconds)
# 60 = once per minute (recommended)
POLL_INTERVAL_SECONDS=60
